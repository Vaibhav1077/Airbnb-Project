# Server
PORT=3000
NODE_ENV=development

# MongoDB
mongo_atlas_url=mongodb+srv://<user>:<password>@cluster.mongodb.net/<dbname>

# Session
MYSECRET=your_session_secret_here

# CORS - Frontend URL allowed to make requests (defaults to http://localhost:5173)
FRONTEND_URL=http://localhost:5173

# Cloudinary
CLOUD_NAME=your_cloud_name
CLOUD_API_KEY=your_api_key
CLOUD_API_SECRET=your_api_secret

# Mapbox
MAP_TOKEN=your_mapbox_token
